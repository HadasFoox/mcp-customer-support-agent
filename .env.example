# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#   cp .env.example .env
#
# Loaded automatically at startup via `spring.config.import` in application.yml.
# A real OS environment variable of the same name overrides what's here.

# Google Gemini API key (https://aistudio.google.com/apikey) — used for both
# chat (gemini-2.5-flash) and embeddings (gemini-embedding-001).
GEMINI_API_KEY=your-gemini-api-key-here

# Optional overrides (defaults live in application.yml):
# DATASET_PATH=data/customer-support-tickets/your-file.csv
# INGEST_MAX_ROWS=750
